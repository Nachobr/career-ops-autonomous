# Personal data (user fills these)
cv.md
data/applications.md
data/pipeline.md
data/scan-history.tsv
reports/*.md
!reports/.gitkeep
output/*
!output/.gitkeep
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/**/*.tsv
!batch/tracker-additions/.gitkeep
jds/*
!jds/.gitkeep

# User config and customization (never auto-updated)
config/profile.yml
portals.yml
modes/_profile.md
.update-dismissed
.update-lock

# Secrets (never commit — use .env.example as template)
.env

# Local LLM runtime (Ollama / LiteLLM / Qwen)
.venv/
*.gguf
Modelfile
litellm_config.yaml
setup_ollama_proxy.sh
download_qwen.py

# Generated
.resolved-prompt-*
node_modules/
bun.lock

# OS
.DS_Store
*.mov
*.mp4

# Claude Code local
.claude/settings.local.json
.claude/memory/
package-lock.json
cv-*.md
*.bak
*.bak-*
data/review-queue.md
data/apply-targets.md
questions.txt

